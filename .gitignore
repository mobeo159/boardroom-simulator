const corsHeaders = {
  'Access-Control-Allow-Origin':
    '*',

  'Access-Control-Allow-Headers':
    [
      'authorization',
      'x-client-info',
      'apikey',
      'content-type',
    ].join(', '),

  'Access-Control-Allow-Methods':
    'POST, OPTIONS',
}

const caseSchema = {
  type: 'object',

  additionalProperties: false,

  required: [
    'title',
    'course_name',
    'description',
    'decision_question',
    'sections',
    'criteria',
  ],

  properties: {
    title: {
      type: 'string',
    },

    course_name: {
      type: 'string',
    },

    description: {
      type: 'string',
    },

    decision_question: {
      type: 'string',
    },

    sections: {
      type: 'array',

      minItems: 1,

      maxItems: 10,

      items: {
        type: 'object',

        additionalProperties:
          false,

        required: [
          'section_key',
          'title',
          'content',
          'sort_order',
        ],

        properties: {
          section_key: {
            type: 'string',
          },

          title: {
            type: 'string',
          },

          sort_order: {
            type: 'integer',
          },

          content: {
            type: 'object',

            additionalProperties:
              false,

            required: [
              'paragraphs',
              'items',
              'decision_meanings',
            ],

            properties: {
              paragraphs: {
                type: 'array',

                items: {
                  type: 'string',
                },
              },

              items: {
                type: 'array',

                items: {
                  type: 'string',
                },
              },

              decision_meanings: {
                type: 'array',

                items: {
                  type: 'string',
                },
              },
            },
          },
        },
      },
    },

    criteria: {
      type: 'array',

      minItems: 2,

      maxItems: 12,

      items: {
        type: 'object',

        additionalProperties:
          false,

        required: [
          'type',
          'title',
          'description',
          'weight',
          'sort_order',
        ],

        properties: {
          type: {
            type: 'string',

            enum: [
              'rational',
              'intuitive',
            ],
          },

          title: {
            type: 'string',
          },

          description: {
            type: 'string',
          },

          weight: {
            type: 'number',

            minimum: 1,

            maximum: 100,
          },

          sort_order: {
            type: 'integer',
          },
        },
      },
    },
  },
}

const extractOutputText = (
  response: Record<
    string,
    unknown
  >,
) => {
  if (
    typeof response.output_text ===
    'string'
  ) {
    return response.output_text
  }

  const output = Array.isArray(
    response.output,
  )
    ? response.output
    : []

  for (const item of output) {
    if (
      typeof item !== 'object' ||
      item === null
    ) {
      continue
    }

    const content =
      'content' in item &&
      Array.isArray(
        item.content,
      )
        ? item.content
        : []

    for (
      const contentItem
      of content
    ) {
      if (
        typeof contentItem ===
          'object' &&
        contentItem !== null &&
        'type' in contentItem &&
        contentItem.type ===
          'output_text' &&
        'text' in contentItem &&
        typeof contentItem.text ===
          'string'
      ) {
        return contentItem.text
      }
    }
  }

  return ''
}

Deno.serve(async (request) => {
  if (
    request.method ===
    'OPTIONS'
  ) {
    return new Response('ok', {
      headers: corsHeaders,
    })
  }

  if (
    request.method !== 'POST'
  ) {
    return Response.json(
      {
        error:
          'Phương thức không được hỗ trợ.',
      },

      {
        status: 405,

        headers:
          corsHeaders,
      },
    )
  }

  try {
    const authorization =
      request.headers.get(
        'Authorization',
      )

    if (!authorization) {
      return Response.json(
        {
          error:
            'Thiếu phiên đăng nhập.',
        },

        {
          status: 401,

          headers:
            corsHeaders,
        },
      )
    }

    const {
      filename,
      documentText,
    } =
      await request.json()

    if (
      typeof documentText !==
        'string' ||
      documentText.trim()
        .length < 200
    ) {
      return Response.json(
        {
          error:
            'Tài liệu có quá ít nội dung.',
        },

        {
          status: 400,

          headers:
            corsHeaders,
        },
      )
    }

    if (
      documentText.length >
      120000
    ) {
      return Response.json(
        {
          error:
            'Tài liệu quá dài. Hãy rút gọn tài liệu trước khi tải lại.',
        },

        {
          status: 400,

          headers:
            corsHeaders,
        },
      )
    }

    const openAIKey =
      Deno.env.get(
        'OPENAI_API_KEY',
      )

    if (!openAIKey) {
      throw new Error(
        'Chưa cấu hình OPENAI_API_KEY trong Supabase Edge Function Secrets.',
      )
    }

    const model =
      Deno.env.get(
        'OPENAI_MODEL',
      ) || 'gpt-5'

    const instructions = `
Bạn là chuyên gia thiết kế case học tập về kỹ năng quản lý và lãnh đạo.

Nhiệm vụ:
Chuyển tài liệu người dùng cung cấp thành một BẢN NHÁP case mô phỏng Hội đồng quản trị.

QUY TẮC BẮT BUỘC:

1. Chỉ sử dụng thông tin có trong tài liệu.
2. Không tự tạo số liệu, tên công ty, ngày tháng hoặc sự kiện.
3. Nếu tài liệu thiếu dữ liệu, phải viết rõ rằng chưa đủ thông tin.
4. Không đưa ra đáp án cuối cùng cho người tham gia.
5. Tách nội dung thành khoảng 4 đến 8 phần phù hợp.
6. Có thể sử dụng các nhóm:
   - Tổng quan tình huống
   - Mục tiêu chiến lược
   - Tài chính
   - Con người và văn hóa
   - Rủi ro
   - Các phương án thay thế
7. Mỗi item nên có cấu trúc:
   "Dữ kiện hoặc tiêu đề: giải thích dữ kiện có ý nghĩa gì."
8. decision_meanings chỉ trình bày ảnh hưởng của dữ kiện đối với quyết định, không đưa ra đáp án bắt buộc.
9. Tạo từ 4 đến 10 tiêu chí đánh giá.
10. Phải có cả tiêu chí rational và intuitive.
11. Tổng trọng số của tất cả tiêu chí phải bằng 100.
12. section_key chỉ dùng chữ thường, số và dấu gạch dưới.
13. Viết bằng tiếng Việt rõ ràng, trung lập, phù hợp sinh viên.
14. Phân biệt rõ dữ kiện đã xảy ra và thông tin dự kiến trong tương lai.
`

    const response =
      await fetch(
        'https://api.openai.com/v1/responses',

        {
          method: 'POST',

          headers: {
            Authorization:
              `Bearer ${openAIKey}`,

            'Content-Type':
              'application/json',
          },

          body: JSON.stringify({
            model,

            store: false,

            instructions,

            input: [
              {
                role: 'user',

                content: [
                  {
                    type:
                      'input_text',

                    text:
                      `Tên file: ${
                        filename ||
                        'document.docx'
                      }

NỘI DUNG TÀI LIỆU:

${documentText}`,
                  },
                ],
              },
            ],

            text: {
              format: {
                type:
                  'json_schema',

                name:
                  'boardroom_case_draft',

                strict: true,

                schema:
                  caseSchema,
              },
            },
          }),
        },
      )

    const responseData =
      await response.json()

    if (!response.ok) {
      console.error(
        responseData,
      )

      throw new Error(
        responseData?.error
          ?.message ||
          'OpenAI API trả về lỗi.',
      )
    }

    const outputText =
      extractOutputText(
        responseData,
      )

    if (!outputText) {
      throw new Error(
        'Không đọc được kết quả từ AI.',
      )
    }

    const caseDraft =
      JSON.parse(outputText)

    return Response.json(
      {
        caseDraft,
      },

      {
        headers: {
          ...corsHeaders,

          'Content-Type':
            'application/json',
        },
      },
    )
  } catch (error) {
    console.error(error)

    return Response.json(
      {
        error:
          error instanceof Error
            ? error.message
            : 'Không thể tạo case.',
      },

      {
        status: 500,

        headers: {
          ...corsHeaders,

          'Content-Type':
            'application/json',
        },
      },
    )
  }
})